# ===================================
# VARIABLES DE ENTORNO - BACKEND CURIEL
# ===================================

# ---- SERVIDOR ----
NODE_ENV=production
PORT=4000
API_VERSION=v1

# ---- BASE DE DATOS (7 Microservicios) ----
# Cada base de datos puede tener su propio password.
# En produccion, usa DATABASE_SSL=true y conexiones SSL.
DATABASE_URL_AUTH="postgres://postgres:TU_PASSWORD_AUTH@localhost:5434/curiel_auth?sslmode=disable"
DATABASE_URL_INSPECCIONES="postgres://postgres:TU_PASSWORD@localhost:5435/curiel_inspecciones?sslmode=disable"
DATABASE_URL_MEDIA="postgres://postgres:TU_PASSWORD@localhost:5436/curiel_media?sslmode=disable"
DATABASE_URL_ADMIN="postgres://postgres:TU_PASSWORD@localhost:5437/curiel_admin?sslmode=disable"
DATABASE_URL_NOTIFICACIONES="postgres://postgres:TU_PASSWORD@localhost:5438/curiel_notificaciones?sslmode=disable"
DATABASE_URL_ALERTAS="postgres://postgres:TU_PASSWORD@localhost:5439/curiel_alertas?sslmode=disable"
DATABASE_URL_AUDITORIA="postgres://postgres:TU_PASSWORD@localhost:5440/curiel_auditoria?sslmode=disable"

# Habilitar en produccion (requiere certificados SSL en el servidor PostgreSQL)
DATABASE_SSL=false

# ---- AUTENTICACIÓN ----
JWT_SECRET=CHANGE_ME_GENERATE_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---- CLOUDINARY (Almacenamiento de fotos) ----
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ---- EMAIL (Nodemailer) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password
FROM_EMAIL=noreply@curiel.com
FROM_NAME=CURIEL Inspecciones

# ---- N8N WEBHOOKS ----
N8N_WEBHOOK_INSPECTION_COMPLETED=https://your-n8n-instance.com/webhook/inspection-completed
N8N_WEBHOOK_USER_NOTIFICATION=https://your-n8n-instance.com/webhook/user-notification
N8N_WEBHOOK_AUDIT_LOG=https://your-n8n-instance.com/webhook/audit-log
N8N_WEBHOOK_EVALUATION_NOTIFICATION=https://your-n8n-instance.com/webhook/evaluation-notification
N8N_SECRET_TOKEN=CHANGE_ME_GENERATE_32_BYTE_HEX_TOKEN

# ---- INTERNAL API KEY (para cron jobs de n8n) ----
# Generar con: openssl rand -hex 32
# Los cron jobs envian este key en el header X-Internal-API-Key
INTERNAL_API_KEY=CHANGE_ME_GENERATE_32_BYTE_HEX_KEY

# ---- CORS ----
CORS_ORIGIN=http://localhost:19006,http://localhost:5173,http://localhost:3000

# ---- UPLOADS ----
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# ---- RATE LIMITING ----
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---- REPORTES PDF ----
COMPANY_LOGO_URL=https://res.cloudinary.com/your-cloud/logo.png
PDF_STORAGE_PATH=./storage/reports

# ---- LOGS ----
LOG_LEVEL=info

# ---- SENTRY (Error Tracking) ----
SENTRY_DSN=

# ---- URLs ----
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:4000
