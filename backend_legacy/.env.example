# ===================================
# VARIABLES DE ENTORNO - BACKEND CURIEL
# ===================================

# ---- SERVIDOR ----
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ---- BASE DE DATOS ----
DB_HOST=localhost
DB_PORT=5432
DB_NAME=curiel_db
DB_USER=postgres
DB_PASSWORD=postgres123
DB_DIALECT=postgres

# Para producción (Railway/Render):
# DATABASE_URL=postgresql://user:password@host:5432/database

# ---- AUTENTICACIÓN ----
JWT_SECRET=curiel_super_secret_key_123
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---- CLOUDINARY (Almacenamiento de fotos) ----
# Crear cuenta gratuita en https://cloudinary.com
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret

# ---- EMAIL (Nodemailer) ----
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_app_password
FROM_EMAIL=noreply@curiel.com
FROM_NAME=CURIEL Inspecciones

# ---- N8N WEBHOOKS ----
N8N_WEBHOOK_INSPECTION_COMPLETED=https://your-n8n-instance.com/webhook/inspection-completed
N8N_WEBHOOK_USER_NOTIFICATION=https://your-n8n-instance.com/webhook/user-notification
N8N_WEBHOOK_AUDIT_LOG=https://your-n8n-instance.com/webhook/audit-log

# ---- CORS ----
# En desarrollo: http://localhost:19006 (Expo)
# En producción: tu dominio
CORS_ORIGIN=http://localhost:19006,http://localhost:8081

# ---- UPLOADS ----
MAX_FILE_SIZE=10485760
# 10MB en bytes
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# ---- RATE LIMITING ----
RATE_LIMIT_WINDOW_MS=900000
# 15 minutos
RATE_LIMIT_MAX_REQUESTS=100

# ---- REPORTES PDF ----
COMPANY_LOGO_URL=https://res.cloudinary.com/your-cloud/logo.png
PDF_STORAGE_PATH=./storage/reports

# ---- LOGS ----
LOG_LEVEL=info
# debug | info | warn | error

# ---- MULTI-TENANT (Futuro) ----
MULTI_TENANT_ENABLED=false

# ---- URLs ----
FRONTEND_URL=http://localhost:19006
BACKEND_URL=http://localhost:4000
