// Migración: curiel_media
// Modelos: Photo, Signature

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PhotoType {
  edificio
  plano
  area
  observacion
  general
}

enum SignatureType {
  inspector
  client
}

model Photo {
  id              String    @id @default(uuid()) @db.Uuid
  inspectionId    String    @map("inspection_id") @db.Uuid
  checklistItemId String?   @map("checklist_item_id") @db.Uuid
  areaId          String?   @map("area_id") @db.Uuid
  observationId   String?   @map("observation_id") @db.Uuid
  type            PhotoType @default(general)
  url             String    @db.VarChar(255)
  publicId        String?   @map("public_id") @db.VarChar(255)
  caption         String?   @db.Text
  latitude        Decimal?  @db.Decimal(10, 8)
  longitude       Decimal?  @db.Decimal(11, 8)
  takenAt         DateTime  @default(now()) @map("taken_at") @db.Timestamptz(6)
  uploadedById    String    @map("uploaded_by_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([inspectionId])
  @@index([areaId])
  @@index([observationId])
  @@index([uploadedById])
  @@index([type])
  @@index([takenAt])
  @@map("photos")
}

model Signature {
  id            String        @id @default(uuid()) @db.Uuid
  inspectionId  String        @map("inspection_id") @db.Uuid
  signatureType SignatureType @map("signature_type")
  signatureUrl  String        @map("signature_url") @db.VarChar(255)
  publicId      String        @map("public_id") @db.VarChar(255)
  signerName    String        @map("signer_name") @db.VarChar(255)
  signedAt      DateTime      @default(now()) @map("signed_at") @db.Timestamptz(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([inspectionId])
  @@map("signatures")
}
