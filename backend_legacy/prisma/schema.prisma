// CURIEL - Schema Prisma Unificado (7 Microservicios)
// Relaciones @relation SOLO entre modelos de la MISMA database
// FKs a modelos de OTRA database son Strings UUID sin @relation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================
// ENUMS - curiel_auth
// ========================

enum DocumentType {
  dni
  ruc
  ce
}

// ========================
// ENUMS - curiel_inspecciones
// ========================

enum InspectionStatus {
  pendiente
  en_proceso
  lista_revision
  finalizada
  cancelada
  reprogramada
}

enum InspectionAreaStatus {
  pendiente
  en_revision
  observado
  aprobado
}

enum ObservationSeverity {
  leve
  media
  alta
  critica
}

enum ObservationType {
  humedad
  electrico
  sanitario
  acabados
  carpinteria
  estructura
  seguridad
  otro
}

enum ObservationStatus {
  pendiente
  corregido
  requiere_revision
}

enum ReportStatus {
  borrador
  listo_para_revision
  aprobado
}

enum InspectionResponseStatus {
  cumple
  no_cumple
  no_aplica
}

// ========================
// ENUMS - curiel_media
// ========================

enum PhotoType {
  edificio
  plano
  area
  observacion
  general
}

enum SignatureType {
  inspector
  client
}

// ========================
// ENUMS - curiel_alertas
// ========================

enum AlertStatus {
  abierta
  en_revision
  resuelta
}

enum SuspensionReason {
  abandono
  rendimiento
  conducta
  otro
}

enum SuspensionStatus {
  activa
  levantada
}

enum EvaluationStatus {
  borrador
  confirmada
  enviada
}

// ============================================
// MODELOS - curiel_auth (5 modelos)
// ============================================

model User {
  id             String   @id @default(uuid()) @db.Uuid
  fullName       String   @map("full_name") @db.VarChar(255)
  email          String   @unique @db.VarChar(255)
  phone          String?  @db.VarChar(255)
  passwordHash   String   @map("password_hash") @db.VarChar(255)
  isActive       Boolean  @default(true) @map("is_active")
  isMasterAdmin  Boolean  @default(false) @map("is_master_admin")
  createdBy      String?  @map("created_by") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones DENTRO de curiel_auth
  roles        UserRole[]
  refreshTokens RefreshToken[]
  resetTokens   PasswordResetToken[]

  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(255)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones DENTRO de curiel_auth
  users UserRole[]

  @@map("roles")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedBy String?  @map("assigned_by") @db.Uuid

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id              String    @id @default(uuid()) @db.Uuid
  token           String    @unique @db.VarChar(512)
  userId          String    @map("user_id") @db.Uuid
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz(6)
  replacedByToken String?   @map("replaced_by_token") @db.VarChar(512)
  ipAddress       String?   @map("ip_address") @db.VarChar(255)
  userAgent       String?   @map("user_agent") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

// ============================================
// MODELOS - curiel_inspecciones (6 modelos)
// ============================================

model Inspection {
  id             String           @id @default(uuid()) @db.Uuid
  projectName    String           @map("project_name") @db.VarChar(255)
  clientName     String           @map("client_name") @db.VarChar(255)
  clientEmail    String?          @map("client_email") @db.VarChar(255)
  clientPhone    String?          @map("client_phone") @db.VarChar(255)
  address        String           @db.Text
  city           String?          @db.VarChar(255)
  state          String?          @db.VarChar(255)
  zipCode        String?          @map("zip_code") @db.VarChar(255)
  inspectionType String           @map("inspection_type") @db.VarChar(255)
  status         InspectionStatus @default(pendiente)
  scheduledDate  DateTime         @map("scheduled_date") @db.Timestamptz(6)
  completedDate  DateTime?        @map("completed_date") @db.Timestamptz(6)
  inspectorId    String           @map("inspector_id") @db.Uuid
  createdById    String           @map("created_by_id") @db.Uuid
  notes          String?          @db.Text
  reportUrl      String?          @map("report_url") @db.VarChar(255)
  latitude       Decimal?         @db.Decimal(10, 8)
  longitude      Decimal?         @db.Decimal(11, 8)
  clientId       String?          @map("client_id") @db.Uuid
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones DENTRO de curiel_inspecciones
  statusHistory InspectionStatusHistory[]
  areas         InspectionArea[]
  observations  InspectionObservation[]
  summary       InspectionSummary?
  responses     InspectionResponse[]

  // FKs a OTRAS databases (sin @relation)
  // inspectorId -> curiel_auth.User.id
  // createdById -> curiel_auth.User.id
  // clientId -> curiel_admin.Client.id

  @@index([inspectorId])
  @@index([createdById])
  @@index([clientId])
  @@index([status])
  @@index([scheduledDate])
  @@map("inspections")
}

model InspectionStatusHistory {
  id              String   @id @default(uuid()) @db.Uuid
  inspectionId    String   @map("inspection_id") @db.Uuid
  changedByUserId String   @map("changed_by_user_id") @db.Uuid
  fromStatus      String   @map("from_status") @db.VarChar(50)
  toStatus        String   @map("to_status") @db.VarChar(50)
  reasonCode      String?  @map("reason_code") @db.VarChar(100)
  reasonLabel     String?  @map("reason_label") @db.VarChar(255)
  comment         String?  @db.Text
  notifyClient    Boolean  @default(false) @map("notify_client")
  notifyInspector Boolean  @default(false) @map("notify_inspector")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  // changedByUserId -> curiel_auth.User.id

  @@index([inspectionId])
  @@index([changedByUserId])
  @@map("inspection_status_histories")
}

model InspectionArea {
  id               String               @id @default(uuid()) @db.Uuid
  inspectionId     String               @map("inspection_id") @db.Uuid
  name             String               @db.VarChar(255)
  category         String               @default("interior") @db.VarChar(255)
  lengthM          Decimal?             @map("length_m") @db.Decimal(10, 2)
  widthM           Decimal?             @map("width_m") @db.Decimal(10, 2)
  calculatedAreaM2 Decimal?             @map("calculated_area_m2") @db.Decimal(10, 2)
  ceilingHeightM   Decimal?             @map("ceiling_height_m") @db.Decimal(10, 2)
  notes            String?              @db.Text
  status           InspectionAreaStatus @default(pendiente)
  sortOrder        Int                  @default(0) @map("sort_order")
  createdAt        DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones DENTRO de curiel_inspecciones
  inspection   Inspection            @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  observations InspectionObservation[]

  @@index([inspectionId])
  @@index([category])
  @@index([status])
  @@index([sortOrder])
  @@map("inspection_areas")
}

model InspectionObservation {
  id             String            @id @default(uuid()) @db.Uuid
  inspectionId   String            @map("inspection_id") @db.Uuid
  areaId         String            @map("area_id") @db.Uuid
  title          String            @db.VarChar(255)
  description    String            @db.Text
  severity       ObservationSeverity
  type           ObservationType
  recommendation String?           @db.Text
  metricValue    Decimal?          @map("metric_value") @db.Decimal(10, 2)
  metricUnit     String?           @map("metric_unit") @db.VarChar(255)
  status         ObservationStatus @default(pendiente)
  createdBy      String            @map("created_by") @db.Uuid
  createdAt      DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones DENTRO de curiel_inspecciones
  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  area       InspectionArea @relation(fields: [areaId], references: [id], onDelete: Cascade)

  // createdBy -> curiel_auth.User.id

  @@index([inspectionId])
  @@index([areaId])
  @@index([severity])
  @@index([type])
  @@index([status])
  @@index([createdBy])
  @@map("inspection_observations")
}

model InspectionSummary {
  id                   String       @id @default(uuid()) @db.Uuid
  inspectionId         String       @unique @map("inspection_id") @db.Uuid
  totalAreaM2          Decimal      @default(0) @map("total_area_m2") @db.Decimal(10, 2)
  totalObservations    Int          @default(0) @map("total_observations")
  criticalObservations Int          @default(0) @map("critical_observations")
  highObservations     Int          @default(0) @map("high_observations")
  mediumObservations   Int          @default(0) @map("medium_observations")
  lightObservations    Int          @default(0) @map("light_observations")
  generalConclusion    String?      @map("general_conclusion") @db.Text
  finalRecommendations String?      @map("final_recommendations") @db.Text
  reportStatus         ReportStatus @default(borrador) @map("report_status")
  createdAt            DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  @@index([reportStatus])
  @@map("inspection_summaries")
}

model InspectionResponse {
  id              String                 @id @default(uuid()) @db.Uuid
  inspectionId    String                 @map("inspection_id") @db.Uuid
  checklistItemId String                 @map("checklist_item_id") @db.Uuid
  status          InspectionResponseStatus
  observations    String?                @db.Text
  respondedAt     DateTime               @default(now()) @map("responded_at") @db.Timestamptz(6)
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz(6)

  inspection Inspection @relation(fields: [inspectionId], references: [id], onDelete: Cascade)

  // checklistItemId -> curiel_admin.ChecklistItem.id

  @@unique([inspectionId, checklistItemId])
  @@index([inspectionId])
  @@index([checklistItemId])
  @@map("inspection_responses")
}

// ============================================
// MODELOS - curiel_media (2 modelos)
// ============================================

model Photo {
  id              String    @id @default(uuid()) @db.Uuid
  inspectionId    String    @map("inspection_id") @db.Uuid
  checklistItemId String?   @map("checklist_item_id") @db.Uuid
  areaId          String?   @map("area_id") @db.Uuid
  observationId   String?   @map("observation_id") @db.Uuid
  type            PhotoType @default(general)
  url             String    @db.VarChar(255)
  publicId        String?   @map("public_id") @db.VarChar(255)
  caption         String?   @db.Text
  latitude        Decimal?  @db.Decimal(10, 8)
  longitude       Decimal?  @db.Decimal(11, 8)
  takenAt         DateTime  @default(now()) @map("taken_at") @db.Timestamptz(6)
  uploadedById    String    @map("uploaded_by_id") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Todos los FKs son a OTRAS databases (sin @relation)
  // inspectionId -> curiel_inspecciones.Inspection.id
  // checklistItemId -> curiel_admin.ChecklistItem.id
  // areaId -> curiel_inspecciones.InspectionArea.id
  // observationId -> curiel_inspecciones.InspectionObservation.id
  // uploadedById -> curiel_auth.User.id

  @@index([inspectionId])
  @@index([areaId])
  @@index([observationId])
  @@index([uploadedById])
  @@index([type])
  @@index([takenAt])
  @@map("photos")
}

model Signature {
  id            String        @id @default(uuid()) @db.Uuid
  inspectionId  String        @map("inspection_id") @db.Uuid
  signatureType SignatureType @map("signature_type")
  signatureUrl  String        @map("signature_url") @db.VarChar(255)
  publicId      String        @map("public_id") @db.VarChar(255)
  signerName    String        @map("signer_name") @db.VarChar(255)
  signedAt      DateTime      @default(now()) @map("signed_at") @db.Timestamptz(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  // inspectionId -> curiel_inspecciones.Inspection.id

  @@index([inspectionId])
  @@map("signatures")
}

// ============================================
// MODELOS - curiel_admin (3 modelos)
// ============================================

model Client {
  id             String       @id @default(uuid()) @db.Uuid
  documentType   DocumentType @map("document_type")
  documentNumber String       @unique @map("document_number") @db.VarChar(255)
  firstName      String?      @map("first_name") @db.VarChar(255)
  lastName       String?      @map("last_name") @db.VarChar(255)
  razonSocial    String?      @map("razon_social") @db.VarChar(255)
  email          String       @unique @db.VarChar(255)
  phone          String?      @db.VarChar(255)
  address        String?      @db.Text
  isProtected    Boolean      @default(false) @map("is_protected")
  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([documentNumber])
  @@index([email])
  @@map("clients")
}

model ChecklistTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  name           String   @db.VarChar(255)
  description    String?  @db.Text
  inspectionType String   @map("inspection_type") @db.VarChar(255)
  isActive       Boolean  @default(true) @map("is_active")
  createdById    String   @map("created_by_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  // Relaciones DENTRO de curiel_admin
  items ChecklistItem[]

  // createdById -> curiel_auth.User.id

  @@index([createdById])
  @@map("checklist_templates")
}

model ChecklistItem {
  id         String   @id @default(uuid()) @db.Uuid
  templateId String   @map("template_id") @db.Uuid
  itemText   String   @map("item_text") @db.Text
  category   String?  @db.VarChar(255)
  orderIndex Int      @default(0) @map("order_index")
  isRequired Boolean  @default(false) @map("is_required")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  template ChecklistTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("checklist_items")
}

// ========================
// MODELS - curiel_admin (Config)
// ========================

model ApiKey {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(255)
  key         String    @unique @db.VarChar(255)
  type        String    @default("api_key") @db.VarChar(50)
  prefix      String?   @db.VarChar(10)
  isActive    Boolean   @default(true) @map("is_active")
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(6)
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(6)
  createdById String    @map("created_by_id") @db.Uuid
  description String?   @db.Text
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([key])
  @@index([createdById])
  @@map("api_keys")
}

// ============================================
// MODELOS - curiel_notificaciones (1 modelo)
// ============================================

model Notification {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  inspectionId  String?   @map("inspection_id") @db.Uuid
  type          String    @db.VarChar(255)
  title         String    @db.VarChar(255)
  message       String    @db.Text
  readAt        DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  // userId -> curiel_auth.User.id
  // inspectionId -> curiel_inspecciones.Inspection.id

  @@index([userId])
  @@index([inspectionId])
  @@map("notifications")
}

// ============================================
// MODELOS - curiel_alertas (3 modelos)
// ============================================

model Alert {
  id            String      @id @default(uuid()) @db.Uuid
  inspectionId  String?     @map("inspection_id") @db.Uuid
  suspensionId  String?     @map("suspension_id") @db.Uuid
  supervisorId  String      @map("supervisor_id") @db.Uuid
  gravityLevel  Int         @map("gravity_level")
  title         String      @db.VarChar(255)
  description   String      @db.Text
  status        AlertStatus @default(abierta)
  notifiedUsers Json        @default("[]") @map("notified_users") @db.Json
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  // inspectionId -> curiel_inspecciones.Inspection.id
  // supervisorId -> curiel_auth.User.id
  // suspensionId -> curiel_alertas.Suspension.id (MISMA database, pero Prisma no puede resolverlo porque Suspension está en otra DB)

  @@index([inspectionId])
  @@index([suspensionId])
  @@index([supervisorId])
  @@index([status])
  @@map("alerts")
}

model Suspension {
  id            String           @id @default(uuid()) @db.Uuid
  inspectorId   String           @map("inspector_id") @db.Uuid
  supervisorId  String           @map("supervisor_id") @db.Uuid
  reason        SuspensionReason
  description   String           @db.Text
  gravityLevel  Int              @map("gravity_level")
  status        SuspensionStatus @default(activa)
  evidence      Json             @default("[]") @db.Json
  createdAt     DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)

  // inspectorId -> curiel_auth.User.id
  // supervisorId -> curiel_auth.User.id

  @@index([inspectorId])
  @@index([supervisorId])
  @@index([status])
  @@map("suspensions")
}

model Evaluation {
  id                     String          @id @default(uuid()) @db.Uuid
  evaluatedUserId        String          @map("evaluated_user_id") @db.Uuid
  supervisorId           String          @map("supervisor_id") @db.Uuid
  weekStart              DateTime        @map("week_start") @db.Date
  weekEnd                DateTime        @map("week_end") @db.Date
  inspectionsCompleted   Int             @default(0) @map("inspections_completed")
  avgTimePerInspection   Float           @default(0) @map("avg_time_per_inspection")
  punctualityRate        Float           @default(0) @map("punctuality_rate")
  avgPhotosPerInspection Float           @default(0) @map("avg_photos_per_inspection")
  criticalObservations   Int             @default(0) @map("critical_observations")
  rejectionRate          Float           @default(0) @map("rejection_rate")
  completionRate         Float           @default(0) @map("completion_rate")
  compositeScore         Float           @default(0) @map("composite_score")
  notes                  String?         @db.Text
  actions                String?         @db.Text
  status                 EvaluationStatus @default(borrador)
  createdAt              DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt              DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  // evaluatedUserId -> curiel_auth.User.id
  // supervisorId -> curiel_auth.User.id

  @@unique([evaluatedUserId, weekStart, weekEnd])
  @@index([evaluatedUserId])
  @@index([supervisorId])
  @@index([weekStart])
  @@index([weekEnd])
  @@map("evaluations")
}

// ============================================
// MODELOS - curiel_auditoria (1 modelo)
// ============================================

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(255)
  entityType String?  @map("entity_type") @db.VarChar(255)
  entityId   String?  @map("entity_id") @db.Uuid
  changes    Json?    @db.JsonB
  ipAddress  String?  @map("ip_address") @db.VarChar(255)
  userAgent  String?  @map("user_agent") @db.Text
  details    Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // userId -> curiel_auth.User.id

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}
