# ==========================================
# CURIEL - .gitignore
# ==========================================

# ============ GENERAL ============
.DS_Store
.env
.env.local
.env.production
*.log
*.lock
.vscode/
.idea/

# ============ NODE ============
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json
yarn.lock
!backend_legacy/package-lock.json
!frontend/package-lock.json
!mobile/package-lock.json

# ============ BACKEND ============
backend_legacy/.env
backend_legacy/node_modules/
backend_legacy/uploads/*
!backend_legacy/uploads/.gitkeep
backend_legacy/storage/reports/*
!backend_legacy/storage/reports/.gitkeep
backend_legacy/dist/
backend_legacy/build/

# ============ MOBILE ============
mobile/node_modules/
mobile/.expo/
mobile/.expo-shared/
mobile/dist/
mobile/web-build/
mobile/*.jks
mobile/*.p8
mobile/*.p12
mobile/*.key
mobile/*.mobileprovision
mobile/*.orig.*

# ============ SECRETS ============
*.pem
*.key
*.cert
.env*
!.env.example

# ============ BUILDS ============
*.apk
*.aab
*.ipa
build/
dist/

# ============ DATABASES ============
*.sqlite
*.db

# ============ OS ============
Thumbs.db
Desktop.ini
._*

# ============ TESTING ============
coverage/
.nyc_output/
*.test.js.snap

# ============ TEMP ============
temp/
tmp/
.cache/
